# ---- Caribbean Paradise Homes "My Stay" — environment ----
# Copy to .env for local dev, or set these in your host's dashboard.

# Session signing secret — REQUIRED in production. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_HOURS=12

# --- 365Villas / GuestWisely credentials (from wp-admin > Guestwisely) ---
# Leave V365_MOCK=1 to run with sample data and NO real credentials.
# To go live: set V365_MOCK=0 (or remove it) and fill these four in.
V365_MOCK=1
V365_KEY=
V365_PASS=
V365_OWNER_TOKEN=
V365_USERNAME=
V365_BASE_URL=https://secure.365villas.com/vros/external-booking/

# --- API mapping (only change if the gated 365Villas docs use other names) ---
# Confirm these on your account's "API & Integrations" page, then adjust.
V365_ACTION_BOOKING_INFO=getbooking
V365_ACTION_PROPERTY_INFO=getinfo
V365_ACTION_PROPERTY_PHOTOS=getphoto
V365_PARAM_REFERENCE=bookingId
V365_PARAM_PROPERTY_ID=propertyId
V365_FIELD_GUEST_LAST=lastName
V365_FIELD_GUEST_FIRST=firstName
V365_FIELD_CHECKIN=checkin
V365_FIELD_CHECKOUT=checkout

# Login throttling
LOGIN_MAX_ATTEMPTS=10

# Set to 1 only while confirming the API mapping (echoes raw PMS data in /api/stay)
V365_DEBUG=0
